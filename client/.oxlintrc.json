{
  "$schema": "./node_modules/.pnpm/oxlint@1.68.0/node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "oxc", "import", "eslint", "react"],
  "jsPlugins": [
    {
      "name": "stylistic",
      "specifier": "@stylistic/eslint-plugin"
    }
  ],
  "categories": { "correctness": "error", "style": "warn" },
  "rules": {
    "react/self-closing-comp": ["error", { "component": true, "html": false }],
    "no-empty-function": "error",
    "no-lonely-if": "error",
    "no-useless-return": "error",
    "default-param-last": "error",
    "no-duplicate-imports": ["error", { "includeExports": true }],
    "prefer-template": "error",
    "prefer-arrow-callback": "error",
    "no-return-assign": "error",
    "object-shorthand": "error",
    "no-unneeded-ternary": "error",
    "curly": ["error", "multi-line"],
    "id-length": "off",
    "unicorn/no-null": "off",
    "capitalized-comments": "off",
    "no-ternary": "off",
    "sort-imports": "off",
    "sort-keys": ["error", "asc", { "caseSensitive": false, "natural": true }],
    "import/no-cycle": "error",
    "stylistic/object-curly-spacing": ["error", "always"],
    "stylistic/array-bracket-spacing": "off",
    "func-style": ["error", "declaration"],
    "react/jsx-max-depth": "off",
    "no-magic-numbers": "off",
    "react/jsx-props-no-spreading": "off",
    "max-statements": "off",
    "import/no-named-export": "off",
    "import/group-exports": "off",
    "max-params": "off",
    "react/exhaustive-deps": "off",
    "react/jsx-boolean-value": ["error", "always"],
    "stylistic/no-multiple-empty-lines": ["error", { "max": 1 }],
    "stylistic/nonblock-statement-body-position": ["error", "beside"],
    "import/newline-after-import": "off",
    "stylistic/padded-blocks": ["error", "never"],
    "stylistic/padding-line-between-statements": ["error", { "blankLine": "always", "prev": "*", "next": "return" }],
    "stylistic/no-confusing-arrow": "error",
    "import/prefer-default-export": "off",
    "prefer-named-capture-group": "off",
    "no-continue": "off"
  },
  "env": { "browser": true, "node": true }
}
